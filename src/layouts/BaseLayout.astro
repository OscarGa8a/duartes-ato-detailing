---
import SEOHead from '../components/seo/SEOHead.astro';
import Navbar from '../components/layout/Navbar.astro';
import Footer from '../components/layout/Footer.astro';
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <script is:inline>
      document.documentElement.classList.add('js');
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <SEOHead title={title} description={description} ogImage={ogImage} />
    <style>
      .gslide-media {
        height: auto !important;
      }
    </style>
  </head>
  <body>
    <ClientRouter />
    <Navbar />
    <main>
      <slot />
    </main>
    <Footer />
    <script>
      let revealObserver: IntersectionObserver | null = null;
      let countupObserver: IntersectionObserver | null = null;

      function initScrollReveal() {
        document.documentElement.classList.add('js');

        if (revealObserver) revealObserver.disconnect();

        const elements = document.querySelectorAll<HTMLElement>('[data-reveal]');
        if (!elements.length) return;

        elements.forEach((el) => el.classList.remove('is-visible'));

        revealObserver = new IntersectionObserver(
          (entries, observer) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            });
          },
          { threshold: 0.1, rootMargin: '0px 0px -6% 0px' }
        );

        elements.forEach((el) => revealObserver!.observe(el));
      }

      function animateCount(el: HTMLElement) {
        if (el.dataset.countAnimated === 'true') return;

        const target = Number(el.dataset.countTo ?? '0');
        if (!Number.isFinite(target)) return;

        const prefix = el.dataset.countPrefix ?? '';
        const suffix = el.dataset.countSuffix ?? '';
        const duration = Number(el.dataset.countDuration ?? '1600');
        const decimals = Number(el.dataset.countDecimals ?? '0');
        const startValue = Number(el.dataset.countFrom ?? '0');
        const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const formatter = new Intl.NumberFormat('en-US', {
          minimumFractionDigits: decimals,
          maximumFractionDigits: decimals,
        });

        const setValue = (value: number) => {
          el.textContent = `${prefix}${formatter.format(value)}${suffix}`;
        };

        el.dataset.countAnimated = 'true';

        if (reduceMotion) {
          setValue(target);
          return;
        }

        const startedAt = performance.now();

        const tick = (now: number) => {
          const progress = Math.min((now - startedAt) / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          const value = startValue + (target - startValue) * eased;
          setValue(progress === 1 ? target : value);

          if (progress < 1) requestAnimationFrame(tick);
        };

        requestAnimationFrame(tick);
      }

      function initCountups() {
        if (countupObserver) countupObserver.disconnect();

        const counters = document.querySelectorAll<HTMLElement>('[data-count-to]');
        if (!counters.length) return;

        countupObserver = new IntersectionObserver(
          (entries, observer) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              animateCount(entry.target as HTMLElement);
              observer.unobserve(entry.target);
            });
          },
          { threshold: 0.55 }
        );

        counters.forEach((counter) => {
          if (counter.dataset.countAnimated === 'true') return;
          countupObserver!.observe(counter);
        });
      }

      function initPageMotion() {
        initScrollReveal();
        initCountups();
      }

      document.addEventListener('astro:after-swap', () => {
        document.documentElement.classList.add('js');
      });
      document.addEventListener('astro:page-load', initPageMotion);
      initPageMotion();
    </script>
  </body>
</html>
