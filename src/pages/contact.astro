---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/ui/PageHero.astro';
import ServiceMap from '../components/sections/contact/ServiceMap.astro';
import ContactSection from '../components/sections/contact/ContactSection.astro';
---

<BaseLayout
  title="Contact - Duartes Auto Detailing"
  description="Book your premium detailing service. Contact us via WhatsApp, text message, Instagram, or email. 100% mobile service in the Bay Area."
>
  <PageHero
    title="Reach Out The Premium Way"
    backgroundImage={{ mobile: 'banner-contact-mobile_jzga4x', desktop: 'banner-contact-web_swobze' }}
    eyebrow="Contact Duartes"
    description="Choose the channel that feels easiest for you and we will help you schedule premium mobile detailing with the speed, clarity, and care you expect."
  />
  <ContactSection />
  <ServiceMap />
</BaseLayout>
