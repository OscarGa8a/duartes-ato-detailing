---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ServiceDetailHero from '../../components/sections/services/ServiceDetailHero.astro';
import ServiceVideoEmbed from '../../components/sections/services/ServiceVideoEmbed.astro';
import RelatedServices from '../../components/sections/services/RelatedServices.astro';
import CTABanner from '../../components/ui/CTABanner.astro';
import { services, getRelatedServices } from '../../data/services';
import { config } from '../../data/config';

export function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
const related = getRelatedServices(service.relatedSlugs);

const pageTitle = service.name;
const pageDescription = service.tagline;
const ogImage = service.ogImage ?? '/images/og-services.jpg';

const phoneMessage = encodeURIComponent(`Hello, I'd like to book the service: ${service.name}`);
const phoneUrl = `sms:${config.phoneUSE164}?body=${phoneMessage}`;
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  ogImage={ogImage}
>
  <ServiceDetailHero service={service} />

  {service.video && (
    <ServiceVideoEmbed video={service.video} serviceSlug={service.slug} />
  )}

  <CTABanner
    image="/images/about-cta.jpg"
    eyebrow="Ready to experience the difference?"
    title="Schedule Your Appointment Today"
    buttonText="Book Your Service"
    buttonHref={phoneUrl}
    buttonTarget="_blank"
  />

  {related.length > 0 && (
    <RelatedServices services={related} />
  )}
</BaseLayout>
