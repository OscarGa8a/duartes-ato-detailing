---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/ui/PageHero.astro';
import StandardSection from '../components/sections/about/StandardSection.astro';
import PillarsSection from '../components/sections/about/PillarsSection.astro';
import BehindTheShine from '../components/sections/about/BehindTheShine.astro';
import CTABanner from '../components/ui/CTABanner.astro';
import { config } from '../data/config';

const phoneMessage = encodeURIComponent(`Hello, I'd like to learn more about your services. Could you provide me with more information?`);
const phoneUrl = `sms:${config.phoneUSE164}?body=${phoneMessage}`;
---

<BaseLayout
  title="About Us | Duartes Auto Detailing"
  description="Meet Duartes Auto Detailing — 3 years in business, with over 5,000 vehicles detailed throughout the Bay Area, California."
>
  <PageHero
    title="Built Around Precision"
    backgroundImage={{ mobile: 'banner-about-mobile_hgfxrs', desktop: 'banner_about-web_yivhwv' }}
    eyebrow="About Duartes"
    description="For more than three years, Duartes Auto Detailing has delivered mobile detailing with the discipline, polish, and premium care Bay Area owners expect from a true luxury service experience."
  />
  <StandardSection />
  <PillarsSection />
  <BehindTheShine />
  <CTABanner
    image="about-cta_xhm8le"
    eyebrow="Ready to experience the difference?"
    title="Schedule Your Appointment Today"
    description="Reserve your appointment and let us bring the Duartes standard directly to your driveway, office, or private garage."
    buttonText="Book Your Service"
    buttonHref={phoneUrl}
    buttonTarget="_blank"
    variant="premium"
  />
</BaseLayout>
