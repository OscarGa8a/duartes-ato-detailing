---
import { socialNetworks } from "../../data/social-networks";
import Icon from "../ui/Icon.astro";


---

<footer class="bg-black border-t border-border py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col items-center gap-5">
    <!-- Logo -->
    <a href="/">
      <img
        src="/images/logo.png"
        alt="Duartes Auto Detailing"
        width="auto"
        height="40"
        class="h-10 w-auto object-contain"
      />
    </a>

    <!-- Social icons -->
    <ul class="flex items-center gap-3">
      {socialNetworks.map(({ name, href }) => (
      <li class="flex justify-center items-center size-8 bg-white rounded-full hover:opacity-80">
        <a href={href} target="_blank" class="text-black">
          <Icon name={name} size="md" />  
        </a>
      </li>
      ))}
    </ul>

    <p class="text-text-muted text-xs text-center">
      &copy; {new Date().getFullYear()} Duartes Auto Detailing. All rights reserved.
    </p>
  </div>
</footer>
