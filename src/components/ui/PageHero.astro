---
import { CldImage } from 'astro-cloudinary';
import { getCloudinaryImageUrl } from '../../helpers/cloudinary';

interface Props {
  title: string;
  backgroundImage: {
    mobile: string;
    desktop: string;
  };
  eyebrow?: string;
  description?: string;
}

const {
  title,
  backgroundImage,
  eyebrow,
  description,
} = Astro.props;

const mobileSrc = getCloudinaryImageUrl(
  backgroundImage.mobile,
  'f_auto,q_auto,w_900,c_fill,g_auto'
);
const desktopSrc = getCloudinaryImageUrl(
  backgroundImage.desktop ?? backgroundImage.mobile,
  'f_auto,q_auto,w_2000,c_fill,g_auto'
);

---

<section
  class="relative flex items-center bg-black overflow-hidden min-h-[calc(72dvh-80px)] lg:min-h-[calc(82dvh-80px)] border-b border-border-soft"
>
  <picture class="absolute inset-0">
    <source media="(min-width: 1024px)" srcset={desktopSrc} />
    <img
      src={mobileSrc}
      alt={title}
      class="absolute inset-0 h-full w-full object-cover page-hero__image object-right"
      loading="eager"
    />
  </picture>
  <!-- <CldImage
    src={backgroundImage}
    alt={title} 
    width={1920}
    height={1080}
    sizes="100vw"
    class="absolute inset-0 w-full h-full object-cover page-hero__image object-[58%_center]"
    loading="eager"
  /> -->

  <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(15,16,18,0.96)_0%,rgba(15,16,18,0.86)_28%,rgba(15,16,18,0.56)_52%,rgba(15,16,18,0.6)_100%),linear-gradient(180deg,rgba(15,16,18,0.14)_0%,rgba(15,16,18,0.56)_100%)]"></div>
  
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(212,175,55,0.16),transparent_30%),radial-gradient(circle_at_bottom_right,rgba(255,255,255,0.06),transparent_26%)]"></div>
  <div class="motion-drift absolute -left-8 top-14 h-56 w-56 rounded-full bg-gold/12 blur-3xl"></div>
  <div class="motion-drift absolute -bottom-10 right-0 h-64 w-64 rounded-full bg-off-white/8 blur-3xl" style="--float-delay: 1.1s"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
    <div class="max-w-2xl flex flex-col gap-5 py-10 lg:py-16">
      {eyebrow && (
        <span class="motion-enter inline-flex items-center gap-3 text-xs font-semibold uppercase tracking-wide text-gold">
          <span class="h-px w-10 bg-gold"></span>
          {eyebrow}
        </span>
      )}
      <h1 class="motion-enter text-display font-bold text-left text-text-primary text-balance max-w-xl" style="--enter-delay: 120ms">
        {title}
      </h1>
      {description && (
        <p class="motion-enter max-w-xl text-base lg:text-lg leading-relaxed text-text-secondary" style="--enter-delay: 220ms">
          {description}
        </p>
      )}
    </div>
  </div>
</section>

<style>
  .page-hero__image {
    animation: page-hero-pan 15s ease-in-out infinite;
  }

  @keyframes page-hero-pan {
    0%,
    100% {
      transform: scale(1.02);
    }

    50% {
      transform: scale(1.08);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .page-hero__image {
      animation: none;
    }
  }
</style>
