---
interface Props {
  title: string;
  backgroundImage: string;
}

const { title, backgroundImage } = Astro.props;
---

<section
  class="relative flex items-end min-h-[220px] bg-black overflow-hidden"
  style={`background-image: url('${backgroundImage}'); background-size: cover; background-position: center;`}
>
  <!-- Dark overlay -->
  <div class="absolute inset-0 bg-black/65"></div>

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-8 w-full">
    <h1 class="text-4xl md:text-5xl font-bold text-white">{title}</h1>
  </div>
</section>
