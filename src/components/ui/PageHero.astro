---
import { CldImage } from 'astro-cloudinary';

interface Props {
  title: string;
  backgroundImage: string;
}

const { title, backgroundImage } = Astro.props;
---

<section
  class="relative flex items-center min-h-80 bg-black overflow-hidden"
>
  <CldImage
    src={backgroundImage}
    alt={title}
    width={1920}
    height={1080}
    sizes="100vw"
    class="absolute inset-0 w-full h-full object-cover"
    loading="eager"
  />

  <!-- Dark overlay -->
  <div class="absolute inset-0 bg-black/65"></div>

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
    <h1 class="text-h1 font-bold text-center md:text-left text-white">{title}</h1>
  </div>
</section>
