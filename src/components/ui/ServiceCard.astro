---
import { CldImage } from 'astro-cloudinary';
import Button from './Button.astro';

interface Props {
  image: string;
  title: string;
  description: string;
  href?: string;
}

const { image, title, description, href } = Astro.props;

---

<article class="rounded-xl overflow-hidden flex flex-col h-full bg-surface-2 border border-border-soft shadow-lg">
  <div class="aspect-video overflow-hidden min-h-70">
    <a href={href} class="block w-full h-full">
      <CldImage
        src={image}
        alt={title}
        width={600}
        height={300}
        sizes="(max-width: 640px) 100vw, 33vw"
        class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
      />
    </a>
  </div>
  <div class="p-5 flex flex-col gap-3 flex-1">
    <h3 class="font-bold text-lg text-text-primary">{title}</h3>
    <p class="text-sm leading-relaxed flex-1 line-clamp-4 text-text-secondary">{description}</p>
    {href && (
      <Button href={href} variant="primary-bright" class="w-full text-center">
        See more details
      </Button>
    )}
  </div>
</article>
