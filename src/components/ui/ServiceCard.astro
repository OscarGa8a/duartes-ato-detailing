---
import { CldImage } from 'astro-cloudinary';
import Button from './Button.astro';

interface Props {
  image: string;
  title: string;
  description: string;
  href?: string;
  variant?: 'light' | 'dark';
}

const { image, title, description, href, variant = 'light' } = Astro.props;

const isDark = variant === 'dark';
const articleClass = isDark
  ? 'bg-surface-2 border border-border-soft shadow-[0_24px_50px_-34px_rgba(15,16,18,0.9)]'
  : 'bg-white shadow-sm';
const titleClass = isDark ? 'text-text-primary' : 'text-text-dark';
const descriptionClass = isDark ? 'text-text-secondary' : 'text-text-muted';
const imageClass = isDark
  ? 'w-full h-full object-cover hover:scale-105 transition-transform duration-500'
  : 'w-full h-full object-cover hover:scale-105 transition-transform duration-300';
---

<article class={`rounded-[1.35rem] overflow-hidden flex flex-col h-full ${articleClass}`}>
  <div class="aspect-video overflow-hidden min-h-70">
    <a href={href} class="block w-full h-full">
      <CldImage
        src={image}
        alt={title}
        width={600}
        height={300}
        sizes="(max-width: 640px) 100vw, 33vw"
        class={imageClass}
      />
    </a>
  </div>
  <div class="p-5 flex flex-col gap-3 flex-1">
    <h3 class={`font-bold text-lg ${titleClass}`}>{title}</h3>
    <p class={`text-sm leading-relaxed flex-1 line-clamp-4 ${descriptionClass}`}>{description}</p>
    {href && (
      <Button href={href} variant="primary-bright" class="w-full text-center">
        See more details
      </Button>
    )}
  </div>
</article>
