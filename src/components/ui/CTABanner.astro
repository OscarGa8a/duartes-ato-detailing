---
import { CldImage } from 'astro-cloudinary';
import Button from './Button.astro';
import Icon from './Icon.astro';

interface Props {
  image: string;
  eyebrow: string;
  title: string;
  description?: string;
  buttonText: string;
  buttonHref: string;
  buttonTarget?: string;
  variant?: 'default' | 'premium';
}

const {
  image,
  eyebrow,
  title,
  description,
  buttonText,
  buttonHref,
  buttonTarget,
  variant = 'default',
} = Astro.props;

const isPremium = variant === 'premium';
---

{isPremium ? (
  <section class="bg-black py-10 lg:py-14 relative overflow-hidden">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div data-reveal="scale" class="relative overflow-hidden rounded-4xl border border-gold/20 bg-gold min-h-88 lg:min-h-72 shadow-lg">
        <div class="motion-sheen"></div>
        <div
          class="motion-float-slow opacity-20 lg:opacity-70 w-full lg:w-100 xl:w-120 absolute inset-y-0 left-0 h-full flex items-start"
          data-reveal="left"
          data-reveal-mobile="off"
          style="--reveal-mobile-opacity: 0.18"
        >
          <CldImage
            src={image}
            alt={eyebrow}
            width={1200}
            height={800}
            sizes="(max-width: 640px) 100vw, (max-width: 1024px) 84vw, 40vw"
            class="w-full h-full object-cover object-right"
          />
        </div>

        {/* <div class="absolute inset-0 bg-linear-to-r from-gold via-gold/96 to-gold/82"></div> */}
        <div class="absolute inset-y-0 left-0 w-24 bg-linear-to-r from-black/10 to-transparent"></div>

        <div data-reveal="blur" class="relative z-10 ml-auto flex w-full lg:max-w-xl flex-col items-center justify-center gap-4 px-8 py-10 text-center lg:items-start lg:px-14 lg:text-left">
          <p class="text-black/60 text-sm font-semibold uppercase tracking-wide w-full">{eyebrow}</p>
          <h2 class="text-black font-bold leading-tight text-h1 text-center lg:text-left w-full max-w-xl">
            {title}
          </h2>
          {description && (
            <p class="text-black/72 text-sm max-w-sm leading-relaxed">
              {description}
            </p>
          )}
          <Button class='motion-glow-pulse mx-auto lg:mx-0' href={buttonHref} variant="dark" target={buttonTarget}>
            <Icon name="tabler:phone" class="text-gold" />
            {buttonText}
          </Button>
        </div>
      </div>
    </div>
  </section>
) : (
  <section class="flex flex-col md:flex-row min-h-70 bg-gold overflow-hidden">
    <div
      data-reveal="left"
      data-reveal-mobile="off"
      class="w-full md:w-1/2 xl:w-2/5 min-h-50 max-h-70 md:max-h-100 md:min-h-full md:rounded-r-full"
    >
      <CldImage
        src={image}
        alt={eyebrow}
        width={600}
        height={400}
        sizes="(max-width: 768px) 100vw, 50vw"
        class="w-full h-full object-cover"
      />
    </div>

    <div data-reveal="right" class="w-full md:w-1/2 xl:md:w-3/5 flex flex-col text-center md:text-left items-center md:items-start justify-center px-8 md:px-14 py-10 gap-4">
      <p class="text-black/70 text-xl font-medium uppercase tracking-wider">{eyebrow}</p>
      <h2 class="text-black text-2xl md:text-3xl font-bold leading-tight">{title}</h2>
      <Button href={buttonHref} variant="white" target={buttonTarget}>
        <Icon name="tabler:phone" />
        {buttonText}
      </Button>
    </div>
  </section>
)}
