---
import Button from './Button.astro';

interface Props {
  image: string;
  eyebrow: string;
  title: string;
  buttonText: string;
  buttonHref: string;
  buttonTarget?: string;
}

const { image, eyebrow, title, buttonText, buttonHref, buttonTarget } = Astro.props;
---

<section class="flex flex-col md:flex-row min-h-[280px]">
  <!-- Left: image -->
  <div class="md:w-2/5 min-h-[200px] md:min-h-full overflow-hidden">
    <img
      src={image}
      alt={eyebrow}
      width="600"
      height="400"
      class="w-full h-full object-cover"
    />
  </div>

  <!-- Right: gold bg -->
  <div class="md:w-3/5 bg-gold flex flex-col items-start justify-center px-8 md:px-14 py-10 gap-4">
    <p class="text-black/70 text-sm font-medium uppercase tracking-wider">{eyebrow}</p>
    <h2 class="text-black text-2xl md:text-3xl font-bold leading-tight">{title}</h2>
    <Button href={buttonHref} variant="white" target={buttonTarget}>{buttonText}</Button>
  </div>
</section>
