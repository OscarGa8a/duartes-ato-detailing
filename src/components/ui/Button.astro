---
interface Props {
  variant?: 'primary' | 'outline' | 'outline-dark' | 'dark' | 'white' | 'primary-bright';
  href: string;
  class?: string;
  target?: string;
}

const { variant = 'primary', href, class: className = '', target } = Astro.props;

const base = 'inline-flex items-center justify-center gap-2 px-7 py-3 rounded-full font-semibold text-sm transition-all duration-200 cursor-pointer';

const variants = {
  primary: 'bg-gold text-black hover:bg-gold-dark',
  outline: 'border border-gold text-gold hover:bg-gold/10',
  'outline-dark': 'border border-gold text-text-dark hover:bg-gold/8',
  dark: 'bg-black text-text-primary hover:bg-surface shadow-lg',
  white: 'bg-white text-black hover:bg-off-white',
  'primary-bright': 'relative overflow-hidden text-black bg-linear-to-b from-gold via-[#D4AF37] to-gold-dark border border-[#F4E8BC]/70 shadow-lg transition-all duration-300 hover:from-[#FFE082] hover:via-[#E0BC4A] hover:to-[#C89B1E] hover:shadow-[0_0_0_1px_rgba(255,236,179,0.35),0_10px_26px_rgba(212,175,55,0.38),inset_0_1px_0_rgba(255,250,210,1),inset_0_-2px_8px_rgba(138,106,22,0.4)] active:scale-[0.98]',
};
---

{variant === 'primary-bright' ? (
  <a href={href} target={target} class={`${base} ${variants[variant]} ${className}`}>
    <span class="absolute inset-x-[6%] top-[10%] h-[38%] rounded-full bg-linear-to-b from-white/55 to-transparent blur-[1px]"></span>
    <span class="absolute left-[8%] top-1/2 h-8 w-8 -translate-y-1/2 rounded-full bg-white/20 blur-md"></span>
    <slot />
  </a>
) : (
  <a href={href} target={target} class={`${base} ${variants[variant]} ${className}`}>
    <slot />
  </a>
)}
