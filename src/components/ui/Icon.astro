---
import { Icon as AstroIcon } from "astro-icon/components";

interface Props {
  name: string; // ej: "tabler:menu-2" o "social/whatsapp"
  class?: string;
  title?: string;
  size?: "xs" | "sm" | "md" | "lg" | "xl" | "2xl";
}

const {
  name,
  class: className = "",
  title,
  size = "md",
} = Astro.props;
const sizes = {
  xs: "w-3 h-3",
  sm: "w-4 h-4",
  md: "w-5 h-5",
  lg: "w-6 h-6",
  xl: "w-8 h-8",
  '2xl': "w-10 h-10",
};

---

<AstroIcon
  name={name}
  title={title}
  class={`inline-block shrink-0 align-middle ${sizes[size]} ${className}`}
/>