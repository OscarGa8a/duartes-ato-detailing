---
import { socialNetworks } from '../../../data/social-networks';
import { CldImage } from 'astro-cloudinary';
import Button from '../../ui/Button.astro';
import Icon from '../../ui/Icon.astro';
---

<section class="bg-off-white overflow-hidden relative">
  <div class="lg:hidden absolute -top-24 -right-24 size-52 rounded-full bg-gold/15 blur-3xl pointer-events-none"></div>
  <div class="lg:hidden absolute -bottom-16 -left-16 size-40 rounded-full bg-black/10 blur-3xl pointer-events-none"></div>

  <div class="max-w-7xl mx-auto py-8 sm:py-10 lg:py-16 w-full min-h-[calc(100dvh-80px)] lg:h-[calc(100dvh-80px)]">
    <div class="flex flex-col lg:flex-row items-stretch lg:items-center gap-6 sm:gap-8 lg:gap-0 h-full">

      <!-- Left: text -->
      <div class="lg:w-2/3 flex flex-col justify-center gap-6 sm:gap-7 z-20 px-4 sm:px-6 lg:px-8 max-w-2xl 2xl:max-w-2xl">
        <span class="inline-flex items-center rounded-full border border-gold/35 bg-white/70 px-3.5 py-1.5 text-[10px] sm:text-[11px] font-semibold tracking-[0.14em] text-black/70 uppercase w-fit">
          Concierge Mobile Detailing · Bay Area
        </span>

        <h1 class="text-black font-bold leading-[1.03] text-[clamp(2rem,8vw,3.45rem)] lg:text-display text-balance max-w-[14ch]">
          Diamond-Level Finish<br />
          <span class="text-gold">At Your Doorstep</span>
        </h1>

        <p class="text-black/80 text-[0.98rem] sm:text-lg leading-relaxed max-w-md xl:max-w-lg">
          Mobile auto detailing for owners who expect quiet luxury. We clean, restore, and protect your vehicle at your home or office throughout the Bay Area.
        </p>

        <div class="lg:hidden flex items-center gap-2 text-[11px] sm:text-xs font-medium uppercase tracking-widest text-black/55">
          <span>5,000+ vehicles detailed</span>
          <span aria-hidden="true" class="size-1 rounded-full bg-black/35"></span>
          <span>fully mobile</span>
        </div>

        <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 pt-1 sm:pt-2">
          <Button class='w-full sm:w-auto shadow-[0_14px_28px_-20px_rgba(33,33,33,0.75)]' href="/contact" variant="primary">
            <Icon name='tabler:phone' />
            Book Your Service
          </Button>
          <Button class='w-full sm:w-auto bg-white/60 backdrop-blur-[2px]' href="/services" variant="outline-dark">View Services</Button>
        </div>
      </div>

      <!-- Right: hero image -->
      <div class="w-full lg:w-auto z-10 relative lg:absolute lg:top-0 lg:right-0 lg:h-[calc(100dvh-80px)]">
        <div class="flex items-center h-full relative mx-4 sm:mx-6 lg:mx-0 rounded-2xl overflow-hidden border border-black/10 shadow-[0_20px_45px_-30px_rgba(0,0,0,0.45)] lg:rounded-none lg:border-0 lg:shadow-none">
          <CldImage
            src="hero-card-complete_ulpfst"
            alt="Luxury car with premium detailing"
            width={1200}
            height={1200}
            sizes="(max-width: 640px) 92vw, (max-width: 1024px) 84vw, 40vw"
            fetchpriority="high"
            loading="eager"
            class="w-full h-[42vh] min-h-66 max-h-96 object-cover object-[62%_center] lg:w-auto lg:h-140 xl:h-170 2xl:h-200 lg:max-h-full"
          />

          <div class="absolute inset-0 lg:hidden pointer-events-none bg-linear-to-t from-black/60 via-black/18 to-transparent"></div>
          <div class="absolute left-4 bottom-4 lg:hidden inline-flex items-center rounded-full border border-white/35 bg-black/58 backdrop-blur-md px-3.5 py-1.5 text-[10px] sm:text-[11px] font-semibold uppercase tracking-[0.08em] text-white/95">
            At your home or office
          </div>
        </div>
      </div>

      <div class="hidden lg:block absolute top-0 right-0 bg-gold h-full w-1/3 2xl:w-2/5"></div>

      <div class="hidden lg:block absolute bottom-0 right-8 h-20 w-auto z-20">
        <ul class="flex items-center gap-3">
          {socialNetworks.map(({ name, href }) => (
          <li class="bg-black rounded-full p-2 hover:opacity-80">
            <a href={href} target="_blank" class="text-gold">
              <Icon name={name} size="xl" />  
            </a>
          </li>
          ))}
        </ul>
      </div>

    </div>
  </div>

  <div class="hidden lg:block absolute -bottom-1/2 -left-3/10 xl:-left-1/5 opacity-50">
    <CldImage
      src="star_talmlw"
      aria-hidden="true"
      width={800}
      height={800}
      sizes="800px"
      class="size-200 object-contain"
    />
  </div>
</section>
