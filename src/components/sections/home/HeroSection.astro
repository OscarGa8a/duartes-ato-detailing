---
import { socialNetworks } from '../../../data/social-networks';
import Button from '../../ui/Button.astro';
import Icon from '../../ui/Icon.astro';
---

<section class="bg-off-white flex items-center overflow-hidden relative" style="height: calc(100dvh - 80px);">
  <div class="max-w-7xl mx-auto py-16 w-full h-full">
    <div class="flex flex-col lg:flex-row items-center gap-10 lg:gap-0 h-full">

      <!-- Left: text -->
      <div class="lg:w-2/3 flex flex-col gap-6 z-20 px-4 sm:px-6 lg:px-8 max-w-2xl 2xl:max-w-3xl">
        <span class="inline-block bg-gold/20 text-gold text-xs font-semibold px-4 py-1.5 rounded-full tracking-wider uppercase w-fit">
          Premium Service · Bay Area
        </span>
        <h1 class="text-black font-bold leading-tight text-display">
          Diamond-Level Radiance<br />
          <span class="text-gold">Wherever You Are</span>
        </h1>
        <p class="text-black text-lg leading-relaxed max-w-sm xl:max-w-md">
          Premium mobile auto detailing throughout the Bay Area. We clean, restore, and protect your investment with excellence
        </p>
        <div class="flex flex-wrap gap-4 mt-2">
          <Button class='w-full lg:w-auto' href="/contact" variant="primary">
            <Icon name='tabler:phone' />
              Book Your Service
          </Button>
          <Button class='w-full lg:w-auto' href="/services" variant="outline-dark">View Services</Button>
        </div>
      </div>

      <!-- Right: hero image -->
      <div class="flex justify-center items-center w-full h-[calc(100dvh-80px)] lg:w-auto z-10 opacity-10 lg:opacity-100 bottom-full lg:bottom-auto absolute top-0 right-0">
        <img
          src="/images/hero-card-complete.png"
          alt="Auto de lujo con detallado premium"
          width="620"
          height="420"
          class="w-full lg:w-auto h-full lg:h-140 xl:h-170 2xl:h-200 max-h-full object-cover"
          loading="eager"
        />
      </div>

      <div class="hidden lg:block absolute top-0 right-0 bg-gold h-full w-1/3 2xl:w-2/5"></div>

      <div class="hidden lg:block absolute bottom-0 right-8 h-20 w-auto z-20">
        <ul class="flex items-center gap-3">
          {socialNetworks.map(({ name, href }) => (
          <li class="bg-black rounded-full p-2 hover:opacity-80">
            <a href={href} target="_blank" class="text-gold">
              <Icon name={name} size="xl" />  
            </a>
          </li>
          ))}
        </ul>
      </div>

    </div>
  </div>
  <div class="hidden lg:block absolute -bottom-3/10 -left-1/30">
    <img src="/images/star-1.png" alt="Estrella decorativa" class="size-100 object-contain" />
  </div>
</section>
