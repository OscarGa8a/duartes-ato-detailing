---
import Button from '../../ui/Button.astro';
---

<section class="bg-black min-h-screen flex items-center overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 w-full">
    <div class="flex flex-col lg:flex-row items-center gap-10 lg:gap-0">

      <!-- Left: text -->
      <div class="lg:w-1/2 flex flex-col gap-6 z-10">
        <span class="inline-block bg-gold/20 text-gold text-xs font-semibold px-4 py-1.5 rounded-full tracking-wider uppercase w-fit">
          Servicio Premium · Bay Area
        </span>
        <h1 class="text-white font-bold leading-tight" style="font-size: var(--font-size-display);">
          Brillo Nivel Diamante<br />
          <span class="text-gold">Donde Estés</span>
        </h1>
        <p class="text-text-muted text-lg leading-relaxed max-w-md">
          Detallado automotriz premium a domicilio en todo el Área de la Bahía.
          Llevamos el brillo de agencia directamente a tu casa u oficina.
        </p>
        <div class="flex flex-wrap gap-4 mt-2">
          <Button href="/contact" variant="primary">Reserva tu Servicio</Button>
          <Button href="/services" variant="outline">Ver Servicios</Button>
        </div>
      </div>

      <!-- Right: hero image -->
      <div class="lg:w-1/2 flex justify-center lg:justify-end">
        <img
          src="/images/hero-card-complete.png"
          alt="Auto de lujo con detallado premium"
          width="620"
          height="420"
          class="w-full max-w-lg lg:max-w-none object-contain"
          loading="eager"
        />
      </div>
    </div>
  </div>
</section>
