---
import Icon from "../../ui/Icon.astro";
import { testimonials } from "../../../data/testimonials";

---

<section class="bg-black py-10 lg:py-16 overflow-hidden border-b border-border-soft relative">
  <div class="motion-drift absolute right-0 top-0 h-56 w-56 rounded-full bg-gold/8 blur-3xl"></div>
  <div class="motion-drift absolute left-0 bottom-0 h-56 w-56 rounded-full bg-wine/10 blur-3xl" style="--float-delay: 1.1s"></div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col items-center gap-10">

    <div data-reveal="blur" class="flex flex-col items-start gap-3 w-full">
      <span class="inline-flex items-center gap-3 text-xs font-semibold uppercase tracking-wide text-gold">
        <span class="h-px w-10 bg-gold"></span>
        Client words
      </span>
      <h2 class="text-text-primary font-bold text-center text-h2">
        What some of our customers say
      </h2>
      <p class="text-text-secondary leading-relaxed">
        Trusted by owners who want their vehicles to look polished, protected, and ready for every drive.
      </p>
    </div>

    <!-- Embla: overflow-hidden en el viewport corta las mitades laterales -->
    <div data-reveal="fade" style="--reveal-delay: 120ms" class="embla w-full" id="testimonials-embla">
      <div class="embla__viewport w-full overflow-hidden" id="testimonials-viewport">
        <div class="embla__container flex">
          {testimonials.map((t) => (
            <div class="embla__slide shrink-0 min-w-0 pl-4">
              <div class="testimonial-card motion-card-hover relative overflow-hidden border border-border p-6 md:p-8 flex flex-col gap-4 h-full rounded-xl bg-surface-2/92 shadow-lg transition-all duration-300">
                <div class="absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-wine-soft/85 to-transparent opacity-70"></div>
                <div class="testimonial-card__aura absolute -right-8 -top-8 h-28 w-28 rounded-full bg-wine/14 blur-2xl"></div>
                <span aria-hidden="true" class="absolute right-5 top-3 text-5xl leading-none text-wine/18">&rdquo;</span>
                <p class="text-text-primary font-semibold text-sm">— {t.name}</p>
                <p class="text-text-secondary leading-relaxed italic flex-1 line-clamp-6">"{t.text}"</p>
                <!-- Stars -->
                <div class="flex gap-1">
                  {Array(5).fill(null).map(() => (
                    <Icon name="tabler:star-filled" class="text-gold" size="sm" />
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Controls -->
    <div data-reveal="up" style="--reveal-delay: 240ms" class="flex items-center gap-6">
      <button id="testimonials-prev" aria-label="Anterior" class="w-10 h-10 rounded-full border border-border text-text-primary flex items-center justify-center cursor-pointer hover:border-gold hover:text-gold transition-colors">
        <Icon name="arrow-left" size="md" />
      </button>

      <div id="testimonials-dots" class="flex gap-2 flex-wrap justify-center max-w-xs">
        {testimonials.map((_, i) => (
          <button
            aria-label={`Ir al testimonio ${i + 1}`}
            class="w-2 h-2 rounded-full cursor-pointer transition-colors bg-border hover:bg-gold"
            data-index={i}
          ></button>
        ))}
      </div>

      <button id="testimonials-next" aria-label="Siguiente" class="w-10 h-10 rounded-full border border-border text-text-primary flex items-center justify-center cursor-pointer hover:border-gold hover:text-gold transition-colors">
        <Icon name="arrow-right" size="md" />
      </button>
    </div>

  </div>
</section>

<style>
  /* Tamaño de cada slide según breakpoint */
  .embla__slide {
    flex: 0 0 88%;
    max-width: 88%;
  }

  @media (min-width: 640px) {
    .embla__slide {
      flex: 0 0 72%;
      max-width: 72%;
    }
  }

  @media (min-width: 1024px) {
    .embla__slide {
      flex: 0 0 52%;
      max-width: 52%;
    }
  }

  /* Slide inactivo: atenuado y ligeramente reducido */
  .testimonial-card {
    opacity: 0.42;
    transform: scale(0.96);
    transition: opacity 0.4s ease, transform 0.4s ease, border-color 0.4s ease;
  }

  .testimonial-card__aura {
    opacity: 0;
    transform: scale(0.8);
    transition: opacity 0.45s ease, transform 0.45s ease;
  }

  /* Slide activo: full opacity, borde gold sutil */
  .embla__slide.is-selected .testimonial-card {
    opacity: 1;
    transform: scale(1);
    border-color: rgba(141, 74, 76, 0.52);
    box-shadow: 0 28px 60px -38px rgba(110, 43, 44, 0.34);
  }

  .embla__slide.is-selected .testimonial-card__aura {
    opacity: 1;
    transform: scale(1);
  }
</style>

<script>
  import EmblaCarousel from 'embla-carousel';
  import Autoplay from 'embla-carousel-autoplay';

  function initCarousel() {
    const viewport = document.getElementById('testimonials-viewport');
    const prevBtn = document.getElementById('testimonials-prev');
    const nextBtn = document.getElementById('testimonials-next');
    const dots = document.querySelectorAll<HTMLButtonElement>('#testimonials-dots button');
    const slides = document.querySelectorAll<HTMLElement>('#testimonials-embla .embla__slide');

    if (!viewport) return;

    const autoplay = Autoplay({
      delay: 4000,
      stopOnInteraction: false,
      stopOnMouseEnter: true,
    });

    const embla = EmblaCarousel(
      viewport,
      {
        loop: true,
        align: 'center',
        containScroll: false,
      },
      [autoplay]
    );

    function updateUI() {
      const selected = embla.selectedScrollSnap();

      dots.forEach((dot, i) => {
        dot.classList.toggle('bg-gold', i === selected);
        dot.classList.toggle('bg-border', i !== selected);
      });

      slides.forEach((slide, i) => {
        slide.classList.toggle('is-selected', i === selected);
      });
    }

    updateUI();

    embla.on('select', updateUI);
    embla.on('reInit', updateUI);

    prevBtn?.addEventListener('click', () => embla.scrollPrev());
    nextBtn?.addEventListener('click', () => embla.scrollNext());

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => embla.scrollTo(i));
    });

    // Limpieza al salir de la página — evita instancias duplicadas
    document.addEventListener('astro:before-preparation', () => embla.destroy(), { once: true });
  }

  document.addEventListener('astro:page-load', initCarousel);
</script>
