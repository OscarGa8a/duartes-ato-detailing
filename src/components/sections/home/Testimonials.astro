---
const testimonials = [
  {
    name: 'Carlos M.',
    city: 'San Jose, CA',
    text: 'Increíble servicio. Llegaron puntual y dejaron mi SUV como nuevo. El recubrimiento cerámico quedó perfecto.',
  },
  {
    name: 'Maria L.',
    city: 'Santa Clara, CA',
    text: 'Lo mejor que encontré en el Área de la Bahía. Super profesionales y detallistas. 100% recomendado.',
  },
  {
    name: 'Jason R.',
    city: 'Fremont, CA',
    text: 'Contraté la corrección de pintura y quedé sorprendido. Las rayaduras desaparecieron completamente.',
  },
  {
    name: 'Ana G.',
    city: 'Sunnyvale, CA',
    text: 'Muy cómodo que vengan a tu casa. El interior quedó impecable, como cuando salió de la agencia.',
  },
];
---

<section class="bg-surface py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col items-center gap-10">

    <h2 class="text-white font-bold text-center" style="font-size: var(--font-size-h2);">
      Lo que dicen algunos de nuestros clientes
    </h2>

    <!-- Carousel wrapper -->
    <div class="w-full relative overflow-hidden">
      <div id="carousel-track" class="flex transition-transform duration-500 ease-in-out">
        {testimonials.map((t) => (
          <div class="w-full shrink-0 px-4">
            <div class="bg-black rounded-xl p-6 md:p-8 flex flex-col gap-4 max-w-2xl mx-auto">
              <!-- Stars -->
              <div class="flex gap-1">
                {Array(5).fill(null).map(() => (
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-gold" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
              <p class="text-white/90 leading-relaxed italic">"{t.text}"</p>
              <div>
                <p class="text-gold font-semibold">{t.name}</p>
                <p class="text-text-muted text-sm">{t.city}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Controls -->
    <div class="flex items-center gap-6">
      <button id="prev-btn" aria-label="Anterior" class="w-10 h-10 rounded-full border border-border text-white flex items-center justify-center hover:border-gold hover:text-gold transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
      </button>

      <div id="dots" class="flex gap-2">
        {testimonials.map((_, i) => (
          <button
            aria-label={`Ir al testimonio ${i + 1}`}
            class={`w-2 h-2 rounded-full transition-colors ${i === 0 ? 'bg-gold' : 'bg-border'}`}
            data-index={i}
          ></button>
        ))}
      </div>

      <button id="next-btn" aria-label="Siguiente" class="w-10 h-10 rounded-full border border-border text-white flex items-center justify-center hover:border-gold hover:text-gold transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </button>
    </div>
  </div>
</section>

<script>
  const track = document.getElementById('carousel-track') as HTMLElement;
  const dots = document.querySelectorAll('#dots button');
  const total = dots.length;
  let current = 0;
  let autoplayTimer: ReturnType<typeof setInterval>;

  function goTo(index: number) {
    current = (index + total) % total;
    track.style.transform = `translateX(-${current * 100}%)`;
    dots.forEach((d, i) => {
      d.classList.toggle('bg-gold', i === current);
      d.classList.toggle('bg-border', i !== current);
    });
  }

  function startAutoplay() {
    autoplayTimer = setInterval(() => goTo(current + 1), 4000);
  }

  function stopAutoplay() {
    clearInterval(autoplayTimer);
  }

  document.getElementById('prev-btn')?.addEventListener('click', () => { stopAutoplay(); goTo(current - 1); startAutoplay(); });
  document.getElementById('next-btn')?.addEventListener('click', () => { stopAutoplay(); goTo(current + 1); startAutoplay(); });

  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => { stopAutoplay(); goTo(i); startAutoplay(); });
  });

  track.addEventListener('mouseenter', stopAutoplay);
  track.addEventListener('mouseleave', startAutoplay);

  startAutoplay();
</script>
