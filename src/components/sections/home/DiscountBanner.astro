---
import { CldImage } from 'astro-cloudinary';
import Button from '../../ui/Button.astro';
import Icon from '../../ui/Icon.astro';
---

<section class="bg-black py-10 lg:py-14 relative overflow-hidden">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div data-reveal="scale" class="relative overflow-hidden rounded-4xl border border-gold/20 bg-gold min-h-88 lg:min-h-72 shadow-lg">
      <div class="motion-sheen"></div>
      <div
        class="motion-float-slow opacity-20 lg:opacity-70 w-full sm:w-130 xl:w-auto absolute inset-y-0 left-0 h-full flex items-start"
        data-reveal="left"
        data-reveal-mobile="off"
        style="--reveal-mobile-opacity: 0.18"
      >
        <CldImage
          src="cta-discount_de5ruc"
          aria-hidden="true"
          width={1200}
          height={800}
          sizes="(max-width: 640px) 100vw, (max-width: 1024px) 84vw, 40vw"
          class="w-full h-full object-cover object-right"
        />
      </div>
      <div class="absolute inset-y-0 left-0 w-24 bg-linear-to-r from-black/10 to-transparent"></div>

      <div class="relative z-10 ml-auto flex w-full lg:max-w-lg xl:max-w-xl flex-col items-center justify-center gap-4 px-8 py-10 text-center lg:items-start lg:px-14 lg:text-left" data-reveal="blur">
        <p class="text-black/60 text-sm font-semibold uppercase tracking-[0.24em] w-full">Special offer</p>
        <h2 class="text-black font-bold leading-tight text-h1 text-center lg:text-left w-full max-w-[10ch]">
          20% off your first service
        </h2>
        <p class="text-black/72 text-sm max-w-sm leading-relaxed">
          Book today and enjoy 20% off your first premium detailing session anywhere in the Bay Area.
        </p>
        <Button class='motion-glow-pulse ' href="/contact" variant="dark">
          <Icon name="tabler:phone" class="text-gold"  />
          Book Your Service
        </Button>
      </div>
    </div>
  </div>
</section>
