---
import { CldImage } from 'astro-cloudinary';
import Icon from "../../ui/Icon.astro";
import 'glightbox/dist/css/glightbox.css';
import { getCloudinaryImageUrl, getCloudinaryVideoUrl } from '../../../helpers/cloudinary';

const items = [
  {
    src: 'IMG_5748_gbvxin',
    alt: 'Exterior detailed with glossy finish',
    gridArea: '1 / 1 / 3 / 3',
  },
  {
    src: 'IMG_0194_stxrfj',
    alt: 'Engine bay detailed and protected',
    gridArea: '1 / 3 / 2 / 4',
  },
  {
    src: 'IMG_0247_py8wf5',
    alt: 'Clay bar decontamination removal',
    gridArea: '1 / 4 / 2 / 5',
  },
  {
    src: 'IMG_0209_hycnyn',
    alt: 'Paint correction',
    gridArea: '2 / 3 / 3 / 4',
  },
  {
    src: 'IMG_3945_qdqfiw',
    alt: 'Ceramic coating applied',
    gridArea: '2 / 4 / 4 / 5',
  },
  {
    src: 'IMG_7624_rmbqgc',
    alt: 'Interior detailing with leather conditioning',
    gridArea: '3 / 1 / 4 / 3',
  },
  {
    src: 'IMG_9140_bwwvp5',
    alt: 'View process of deep decontamination with clay bar',
    gridArea: '3 / 3 / 4 / 4',
    isVideo: true,
    mediaSrc: 'video_dr86xv',
  },
];
---


<section id="gallery-section" class="bg-off-white py-10 lg:py-16 relative border-b border-divider-light/70 overflow-hidden">
  <div class="motion-drift absolute -left-16 top-28 h-72 w-72 rounded-full bg-gold/10 blur-3xl"></div>
  <div class="motion-drift absolute -right-20 bottom-20 h-60 w-60 rounded-full bg-gold/8 blur-3xl" style="--float-delay: 1.4s"></div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col items-center gap-12">

    <div data-reveal="blur" class="flex flex-col items-start gap-3 text-left w-full">
      <span class="inline-flex items-center gap-3 text-xs font-semibold uppercase tracking-wide text-gold-deep">
        <span class="h-px w-10 bg-gold"></span>
        Finished work
      </span>
      <h2 class="text-text-dark font-bold text-h2">
        Gallery
      </h2>
      <p class="text-text-dark/70 max-w-md text-body">
        Real results. Every detail speaks for itself.
      </p>
    </div>

    <div class="gallery-grid w-full z-10">
      {items.map((item, index) => (
        <button
          type="button"
          aria-label={item.alt}
          class="gallery-item gallery-item--placed motion-card-hover group relative overflow-hidden text-left rounded-xl border border-transparent shadow-lg transition-all duration-300 hover:border-gold/60"
          data-reveal={index === 0 ? 'scale' : 'up'}
          style={`--reveal-delay: ${index * 100}ms`}
          data-grid-area={item.gridArea}
          data-media={item.isVideo ? getCloudinaryVideoUrl(item.mediaSrc) : getCloudinaryImageUrl(item.src, 'f_auto,q_auto,w_1800')}
          data-type={item.isVideo ? 'video' : 'image'}
          data-index={index}
        >
          <CldImage
            src={item.src}
            alt={item.alt}
            width={1000}
            height={600}
            sizes="(max-width: 1024px) 100vw, 50vw"
            class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
          />

          <div class={`absolute inset-0 transition-colors duration-500 ${item.isVideo ? 'bg-black/20 group-hover:bg-black/40' : 'bg-black/0 group-hover:bg-black/25'}`} />

          {item.isVideo ? (
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="w-14 h-14 rounded-full bg-gold flex items-center justify-center shadow-lg transition-transform duration-300 group-hover:scale-110">
                <Icon name="tabler:player-play-filled" class="text-text-dark" size="lg" />
              </div>
            </div>
          ) : (
            <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <div class="w-11 h-11 rounded-full bg-gold/92 flex items-center justify-center shadow-md">
                <Icon name="tabler:search" class="text-text-dark" size="lg" />
              </div>
            </div>
          )}
        </button>
      ))}
    </div>

  </div>

  <div class="hidden lg:block h-full absolute top-0 -left-2/10 opacity-50">
    <CldImage
      src="star_talmlw"
      aria-hidden="true"
      width={1500}
      height={1500}
      sizes="(max-width: 1024px) 84vw, 40vw"
      class="w-auto h-full object-contain!"
    />
  </div>
</section>

<style>
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: repeat(3, 250px);
    gap: 10px;
  }

  @media (max-width: 1023px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: none;
      grid-auto-rows: 250px;
    }
  }

  @media (max-width: 639px) {
    .gallery-grid {
      grid-template-columns: 1fr;
      grid-auto-rows: 220px;
    }
  }

  .gallery-item {
    cursor: pointer;
    border: none;
    padding: 0;
    background: none;
  }


  .gslide-media {
    height: auto !important;
  }

</style>

<script>
  import GLightbox from 'glightbox';

  function applyGridAreas() {
    const items = document.querySelectorAll<HTMLElement>('.gallery-item--placed');
    const w = window.innerWidth;
    items.forEach((el, i) => {
      if (w >= 1024) {
        el.style.gridArea = el.dataset.gridArea ?? '';
      } else if (w >= 640) {
        el.style.gridArea = i === 0 ? '1 / 1 / 2 / 3' : '';
      } else {
        el.style.gridArea = '';
      }
    });
  }

  // applyGridAreas corre en cada navegación (módulo se ejecuta 1 vez,
  // pero astro:page-load dispara en cada navegación)
  document.addEventListener('astro:page-load', applyGridAreas);
  window.addEventListener('resize', applyGridAreas);
  applyGridAreas();

  function stopAllVideos() {
    document.querySelectorAll('.gslide video').forEach((v) => (v as HTMLVideoElement).pause());
  }

  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('#gallery-section .gallery-item');
    if (!btn) return;

    const buttons = Array.from(
      document.querySelectorAll<HTMLButtonElement>('#gallery-section .gallery-item')
    );
    const startAt = buttons.indexOf(btn);

    // Construimos los elementos: imágenes como 'image', video como 'html' con <video> nativo
    // Así GLightbox no activa Plyr y el carousel incluye el video sin CSS externo
    const elements = buttons.map((b, index) => {
      const media = b.dataset.media ?? '';
      if (b.dataset.type === 'video') {
        return {
          content: `<video src="${media}" controls playsinline autoplay
            style="max-height:85dvh;" class="video-${index} block h-auto outline-none rounded-sm bg-black w-auto max-w-full">
          </video>`,
          width: 'auto',
        };
      }
      return {
        href: media,
        type: 'image' as const,
        alt: b.getAttribute('aria-label') ?? '',
      };
    });

    const lb = GLightbox({
      elements: elements as Parameters<typeof GLightbox>[0]['elements'],
      touchNavigation: true,
      loop: true,
      zoomable: true,
      draggable: true,
      openEffect: 'fade',
      closeEffect: 'fade',
      startAt,
    });

    lb.open();

    // Pausar video al cerrar o al cambiar de slide
    lb.on('close', stopAllVideos);

    lb.on('slide_before_change', (event: any) => {
      const currentSlide = event.current;
      if (currentSlide.slideConfig.type === 'image') {
        stopAllVideos();
      } else {
        const video = document.querySelector(`.video-${currentSlide.slideIndex}`) as HTMLVideoElement;
        if (video) video.play();
      }
    });

    if (btn.dataset.type === 'image') stopAllVideos();
  });
</script>
