---
import Icon from "../../ui/Icon.astro";

interface Pillar {
  icon: string;
  title: string;
  description: string;
}

const pillars: Pillar[] = [
  {
    icon: 'tabler:check',
    title: 'Our Mission',
    description: 'We clean, restore, and protect every vehicle with excellence. We add real value to the maintenance and appearance of your car by using top-quality products.',
  },
  {
    icon: 'tabler:target-arrow',
    title: 'Our Vision',
    description: 'To be the leading brand and trusted leader in mobile automotive detailing in the Bay Area and California.',
  },
  {
    icon: 'tabler:star-filled',
    title: 'Our Values',
    description: 'Professionalism, trust, and versatility. We guarantee a comfortable, safe experience and consistent results right at your doorstep.',
  },
];
---

<section class="bg-off-white py-8 lg:py-14">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col items-center gap-8 md:gap-12">

    <h2 class="text-text-dark font-bold text-center text-h2">
      Our Pillars
    </h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 w-full">
      {pillars.map((pillar, index) => (
        <div class={`rounded-xl p-8 flex flex-col items-center text-center gap-5 hover:scale-102 transition-transform ${index === 0 ? "bg-surface" : "bg-surface/90"} ${index === 2 ? "sm:col-span-2 sm:max-w-1/2 sm:mx-auto lg:col-span-1 lg:max-w-none lg:mx-0" : ""}`}>
          <!-- Gold icon circle -->
          <div class="w-12 h-12 rounded-full bg-gold flex items-center justify-center shrink-0">
            <Icon name={pillar.icon} class="text-white" size="lg" />
          </div>
          <div class="flex flex-col gap-2">
            <h3 class="text-white font-bold text-lg">{pillar.title}</h3>
            <p class="text-text-muted text-sm leading-relaxed">{pillar.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
