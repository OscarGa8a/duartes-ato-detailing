---
const pillars = [
  {
    icon: 'target',
    title: 'Nuestra Misión',
    description: 'Limpiar, restaurar y proteger cada vehículo con excelencia, usando los mejores productos y técnicas del mercado.',
  },
  {
    icon: 'star',
    title: 'Nuestra Visión',
    description: 'Ser la marca de detallado móvil líder en el Área de la Bahía, reconocida por calidad, confianza y profesionalismo.',
  },
  {
    icon: 'check',
    title: 'Nuestros Valores',
    description: 'Profesionalismo, confianza y consistencia en cada trabajo — siempre en la puerta de tu casa u oficina.',
  },
];
---

<section class="bg-off-white py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col items-center gap-12">

    <h2 class="text-text-dark font-bold text-center" style="font-size: var(--font-size-h2);">
      Nuestros Pilares
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 w-full">
      {pillars.map((pillar) => (
        <div class="bg-surface rounded-xl p-8 flex flex-col items-start gap-5">
          <!-- Gold icon circle -->
          <div class="w-12 h-12 rounded-full bg-gold flex items-center justify-center shrink-0">
            {pillar.icon === 'target' && (
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-black" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>
              </svg>
            )}
            {pillar.icon === 'star' && (
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-black" viewBox="0 0 20 20" fill="currentColor">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            )}
            {pillar.icon === 'check' && (
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-black" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
              </svg>
            )}
          </div>
          <div class="flex flex-col gap-2">
            <h3 class="text-white font-bold text-lg">{pillar.title}</h3>
            <p class="text-text-muted text-sm leading-relaxed">{pillar.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
