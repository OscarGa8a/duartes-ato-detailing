---
const options = [
  {
    icon: 'whatsapp',
    title: 'Reservar via WhatsApp',
    info: '(669) 28-8649',
    href: 'https://wa.me/16692882864',
    label: 'Abrir WhatsApp',
  },
  {
    icon: 'sms',
    title: 'Enviar un SMS Rápido',
    info: '(669) 28-8649',
    href: 'sms:+16692882864',
    label: 'Enviar SMS',
  },
  {
    icon: 'instagram',
    title: 'Enviar DM en Instagram',
    info: '@duartes_detailing',
    href: 'https://www.instagram.com/duartes_detailing',
    label: 'Ir a Instagram',
  },
];
---

<section class="bg-white py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col items-center gap-10">

    <div class="text-center flex flex-col gap-3">
      <h2 class="text-text-dark font-bold" style="font-size: var(--font-size-h2);">
        ¿Listo para elevar el estándar de tu auto?
      </h2>
      <p class="text-text-muted max-w-xl mx-auto">
        Agenda tu detallado premium hoy. Llevamos el brillo de agencia directamente a tu casa u oficina.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 w-full">
      {options.map((opt) => (
        <a
          href={opt.href}
          target={opt.href.startsWith('http') ? '_blank' : undefined}
          rel={opt.href.startsWith('http') ? 'noopener noreferrer' : undefined}
          aria-label={opt.label}
          class="bg-gold rounded-xl p-7 flex flex-col gap-4 hover:bg-gold-dark transition-colors group"
        >
          <!-- Icon -->
          <div class="w-12 h-12 rounded-full bg-black/15 flex items-center justify-center">
            {opt.icon === 'whatsapp' && (
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-black" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z M12 0C5.373 0 0 5.373 0 12c0 2.116.553 4.103 1.523 5.83L.057 23.177a.75.75 0 0 0 .906.906l5.347-1.466A11.944 11.944 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.806 9.806 0 0 1-5.001-1.371l-.358-.213-3.712 1.018 1.018-3.712-.213-.358A9.806 9.806 0 0 1 2.182 12C2.182 6.57 6.57 2.182 12 2.182S21.818 6.57 21.818 12 17.43 21.818 12 21.818z"/>
              </svg>
            )}
            {opt.icon === 'sms' && (
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-black" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
              </svg>
            )}
            {opt.icon === 'instagram' && (
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-black" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
              </svg>
            )}
          </div>

          <div class="flex flex-col gap-1">
            <span class="text-black font-bold text-base">{opt.title}</span>
            <span class="text-black/70 text-sm">{opt.info}</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
