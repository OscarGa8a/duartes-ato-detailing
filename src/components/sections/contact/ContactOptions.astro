---
import { config } from "../../../data/config";
import Icon from "../../ui/Icon.astro";

interface ContactOption {
  icon: string;
  title: string;
  info: string;
  href: string;
  label: string;
  mobileHref?: string;
}

const message = encodeURIComponent("Hello, Duarte Detailing! I'm interested in booking a detailing service. Could you provide me with more information about your services, prices, and availability? Thank you!");

const options: ContactOption[] = [
  {
    icon: 'tabler:brand-whatsapp',
    title: 'Book via WhatsApp',
    info: config.phoneFormatted,
    href: `https://wa.me/${config.phoneUSE164}?text=${message}`,
    label: 'Open WhatsApp',
  },
  {
    icon: 'tabler:message',
    title: 'Send a Quick Text Message',
    info: config.phoneFormatted,
    href: `sms:${config.phoneUSE164}?body=${message}`,
    label: 'Send SMS',
  },
  {
    icon: 'tabler:brand-instagram',
    title: 'Send a DM on Instagram',
    info: '@duartes_detailing',
    href: 'https://www.instagram.com/direct/t/17842345695295426',
    mobileHref: 'instagram://user?username=duartes_detailing',
    label: 'Go to Instagram',
  },
];
---

<div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-6 w-full">
  {options.map((opt, index) => (
    <a
      data-reveal="scale"
      style={`--reveal-delay: ${index * 120}ms`}
      href={opt.href}
      data-desktop-href={opt.href}
      data-mobile-href={opt.mobileHref}
      data-platform-switch={opt.mobileHref ? "true" : undefined}
      target={opt.href.startsWith('http') ? '_blank' : undefined}
      rel={opt.href.startsWith('http') ? 'noopener noreferrer' : undefined}
      aria-label={opt.label}
      class={`motion-card-hover relative overflow-hidden rounded-xl border border-border-soft bg-surface-2 p-7 flex flex-col gap-5 group ${index === 2 ? "sm:col-span-2 sm:max-w-1/2 sm:w-full sm:mx-auto xl:col-span-1 xl:max-w-none" : ""}`}
    >
      <div class="absolute inset-x-6 top-0 h-px bg-linear-to-r from-transparent via-gold/75 to-transparent"></div>
      <div class="motion-glow-pulse absolute -right-8 -top-8 h-24 w-24 rounded-full bg-gold/8 blur-2xl" style={`--float-delay: ${index * 0.6}s`}></div>

      <div class="w-13 h-13 rounded-full bg-gold flex items-center justify-center shadow-lg">
        <Icon name={opt.icon} class="text-text-dark" size="2xl" />
      </div>

      <div class="flex flex-col gap-2">
        <span class="text-text-primary font-bold text-lg">{opt.title}</span>
        <span class="text-text-secondary text-sm leading-relaxed">{opt.info}</span>
      </div>

      <div class="mt-auto flex items-center justify-between gap-4 pt-2 text-xs font-semibold uppercase tracking-wide text-gold">
        <span>{opt.label}</span>
        <span class="transition-transform duration-300 group-hover:translate-x-1">→</span>
      </div>
    </a>
  ))}
</div>

<script>
  const isMobile = window.matchMedia("(max-width: 1023px)").matches;

  document.querySelectorAll('[data-platform-switch="true"]').forEach((el) => {
    el.addEventListener("click", (e) => {
      if (!isMobile) return;

      e.preventDefault();
      const anchor = el;
      const appUrl = anchor.getAttribute("data-mobile-href");
      const webUrl = anchor.getAttribute("data-desktop-href");

      if (!appUrl || !webUrl) return;

      // Intenta abrir app; si falla, vuelve al link web.
      window.location.href = appUrl;
      setTimeout(() => window.location.href = webUrl, 1200);
    });
  });
</script>
