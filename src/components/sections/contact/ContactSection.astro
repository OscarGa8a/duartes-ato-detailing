---
import ContactForm from "./ContactForm.astro";
import ContactOptions from "./ContactOptions.astro";
---

<section class="bg-black py-10 lg:py-16 overflow-hidden relative border-b border-border-soft">
  <div class="motion-drift absolute -left-12 top-14 h-64 w-64 rounded-full bg-gold/10 blur-3xl"></div>
  <div class="motion-drift absolute right-0 bottom-0 h-64 w-64 rounded-full bg-off-white/6 blur-3xl" style="--float-delay: 1.2s"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col gap-10 lg:gap-14 lg:items-start">
    <div class="flex flex-col gap-6 lg:gap-12 w-full">
      <div data-reveal="blur" class="flex flex-col gap-4">
        <span class="inline-flex items-center gap-3 text-xs font-semibold uppercase tracking-wide text-gold">
          <span class="h-px w-10 bg-gold"></span>
          Contact options
        </span>
        <h2 class="text-text-primary font-bold text-h1">
          Book fast, ask questions, or start the conversation your way.
        </h2>
        <p class="text-text-secondary leading-relaxed">
          Whether you prefer WhatsApp, text, Instagram, or email, we keep the process direct and premium. Pick the channel that feels most natural and we will guide you to the right service.
        </p>
      </div>

      <ContactOptions />
    </div>

    <div class="flex justify-center w-full">
      <ContactForm />
    </div>
  </div>
</section>
