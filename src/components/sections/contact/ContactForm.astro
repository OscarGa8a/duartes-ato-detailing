---
---

<section class="py-8 lg:py-14">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col items-center gap-10">

    <h2 class="text-white font-bold text-center text-h2">
      Send us a message via email
    </h2>

    <form id="contact-form" novalidate class="w-full flex flex-col gap-5">

      <!-- Honeypot (hidden from humans, visible to bots) -->
      <div style="position: absolute; left: -9999px;" aria-hidden="true">
        <label for="website">Leave this blank</label>
        <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
      </div>

      <!-- Row: Nombre + Email + Teléfono -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="flex flex-col gap-1">
          <label for="name" class="sr-only">Name</label>
          <input
            type="text"
            id="name"
            name="name"
            placeholder="Name*"
            aria-required="true"
            class="contact-input bg-transparent border border-gold text-white placeholder:text-white px-4 py-3 focus:outline-none focus:border-gold transition-colors w-full"
          />
          <span class="error-msg text-red-400 text-xs hidden" id="name-error">Your name is required.</span>
        </div>

        <div class="flex flex-col gap-1">
          <label for="email" class="sr-only">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            placeholder="Email*"
            aria-required="true"
            class="contact-input bg-transparent border border-gold text-white placeholder:text-white px-4 py-3 focus:outline-none focus:border-gold transition-colors w-full"
          />
          <span class="error-msg text-red-400 text-xs hidden" id="email-error">Invalid email.</span>
        </div>

        <div class="flex flex-col gap-1">
          <label for="phone" class="sr-only">Phone</label>
          <input
            type="tel"
            id="phone"
            name="phone"
            placeholder="Phone*"
            aria-required="true"
            class="contact-input bg-transparent border border-gold text-white placeholder:text-white px-4 py-3 focus:outline-none focus:border-gold transition-colors w-full"
          />
          <span class="error-msg text-red-400 text-xs hidden" id="phone-error">A phone number is required.</span>
        </div>
      </div>

      <!-- Mensaje -->
      <div class="flex flex-col gap-1">
        <label for="message" class="sr-only">Message</label>
        <textarea
          id="message"
          name="message"
          placeholder="Message*"
          rows="4"
          aria-required="true"
          class="contact-input bg-transparent border border-gold text-white placeholder:text-white px-4 py-3  focus:outline-none focus:border-gold transition-colors w-full resize-none"
        ></textarea>
        <span class="error-msg text-red-400 text-xs hidden" id="message-error">A message is required.</span>
      </div>

      <!-- Submit -->
      <div class="flex justify-center">
        <button
          type="submit"
          class="bg-gold text-black font-semibold w-full sm:w-auto px-20 py-3 rounded-full hover:bg-gold-dark transition-colors text-sm"
        >
          Send
        </button>
      </div>

      <!-- Success message -->
      <div id="success-msg" class="hidden text-center text-green-400 font-medium py-4 rounded-lg bg-green-400/10">
        Message sent! We'll be in touch soon..
      </div>
    </form>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;

  function showError(inputId: string, errorId: string) {
    const input = document.getElementById(inputId) as HTMLInputElement;
    const error = document.getElementById(errorId) as HTMLElement;
    input.classList.add('border-red-500');
    input.classList.remove('border-border');
    error.classList.remove('hidden');
  }

  function clearError(inputId: string, errorId: string) {
    const input = document.getElementById(inputId) as HTMLInputElement;
    const error = document.getElementById(errorId) as HTMLElement;
    input.classList.remove('border-red-500');
    // input.classList.add('border-border');
    error.classList.add('hidden');
  }

  // Clear errors on input
  ['name', 'email', 'phone', 'message'].forEach((field) => {
    document.getElementById(field)?.addEventListener('input', () => clearError(field, `${field}-error`));
  });

  form?.addEventListener('submit', (e) => {
    e.preventDefault();

    // Honeypot check
    const honeypot = document.getElementById('website') as HTMLInputElement;
    if (honeypot.value !== '') return;

    const name = (document.getElementById('name') as HTMLInputElement).value.trim();
    const email = (document.getElementById('email') as HTMLInputElement).value.trim();
    const phone = (document.getElementById('phone') as HTMLInputElement).value.trim();
    const message = (document.getElementById('message') as HTMLTextAreaElement).value.trim();
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

    let valid = true;

    if (!name) { showError('name', 'name-error'); valid = false; }
    if (!email || !emailRegex.test(email)) { showError('email', 'email-error'); valid = false; }
    if (!phone) { showError('phone', 'phone-error'); valid = false; }
    if (!message) { showError('message', 'message-error'); valid = false; }

    if (!valid) return;

    // Show success (backend TBD)
    form.reset();
    const successMsg = document.getElementById('success-msg');
    successMsg?.classList.remove('hidden');
    setTimeout(() => successMsg?.classList.add('hidden'), 5000);
  });
</script>
