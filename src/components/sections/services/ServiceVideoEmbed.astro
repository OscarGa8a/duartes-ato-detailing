---
interface Props {
  videoUrl: string;
}

const { videoUrl } = Astro.props;
---

<section class="bg-white py-16 md:py-20">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col items-center gap-8">

    <h2
      class="text-text-dark font-bold text-center"
      style="font-size: var(--font-size-h2);"
    >
      Mirá un video detallado de este servicio en acción
    </h2>

    <!-- 16:9 aspect ratio wrapper -->
    <div class="w-full rounded-2xl overflow-hidden shadow-lg" style="aspect-ratio: 16 / 9;">
      <iframe
        src={videoUrl}
        title="Video del servicio de detallado automotriz"
        width="100%"
        height="100%"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        allowfullscreen
        loading="lazy"
        class="w-full h-full"
      ></iframe>
    </div>

  </div>
</section>
