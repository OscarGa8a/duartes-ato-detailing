---
import Button from '../../ui/Button.astro';
import ServiceGallery from './ServiceGallery.astro';
import type { Service } from '../../../data/services';
import Icon from '../../ui/Icon.astro';
import { config } from '../../../data/config';

interface Props {
  service: Service;
}

const { service } = Astro.props;

const phoneMessage = encodeURIComponent(`Hello, I'd like to book the service: ${service.name}`);
const phoneUrl = `sms:${config.phoneUSE164}?body=${phoneMessage}`;
---

<section class="flex flex-col lg:flex-row">

  <!-- Left column: dark background, service info -->
  <div
    data-reveal="left"
    data-reveal-mobile="off"
    class="lg:w-1/2 flex flex-col justify-center px-8 md:px-12 lg:px-14 py-8 lg:py-14 gap-6" style="background: linear-gradient(237.94deg, #403F3F 20.28%, #000000 108.74%);"
  >
    <div class="max-w-2xl mx-auto">
      <!-- Service name -->
      <div class="mb-8">
        <h1 class="text-gold font-bold leading-tight text-h1">
          {service.name}
        </h1>
        <p class="text-text-muted mt-2 text-base">{service.tagline}</p>
      </div>
  
      <!-- What does the service include? -->
      <div class="mb-8">
        <h3 class="text-gold font-semibold text-lg mb-4">What does the service include?</h3>
  
        <div class="flex flex-col gap-5">
          {service.includes.map((section) => (
            <div>
              <p class="text-white font-bold text-sm mb-2">{section.label}</p>
              <ul class="flex flex-col gap-1">
                {section.items.map((item) => (
                  <li class="text-text-muted text-sm flex items-start gap-2">
                    <span class="text-gold mt-0.5 shrink-0">•</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
  
      <!-- CTA line + button -->
      <div class="flex flex-col gap-4 mb-4">
        {service.ctaLine && (
          <p class="text-text-muted text-sm italic">{service.ctaLine}</p>
        )}

        <!-- <div class="max-w-xl w-xl">
        </div> -->
        <Button href={phoneUrl} variant="primary" target="_blank" class='w-full max-w-full lg:w-xs'>
          <Icon name="tabler:phone" />
          Book this service
        </Button>
      </div>
  
    </div>
    </div>

  <!-- Right column: white background, gallery -->
  <div class="lg:w-1/2 bg-white flex flex-col justify-center px-8 md:px-12 lg:px-14 py-8 lg:py-14">
    <ServiceGallery images={service.images} serviceName={service.name} />
  </div>

</section>
