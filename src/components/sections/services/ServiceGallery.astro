---
import 'glightbox/dist/css/glightbox.css';
import Icon from '../../ui/Icon.astro';
import { CldImage } from 'astro-cloudinary';
import { getCloudinaryImageUrl } from '../../../helpers/cloudinary';

interface Props {
  images: string[];
  serviceName: string;
}

const { images, serviceName } = Astro.props;
const galleryImages = Array.isArray(images) ? images.filter(Boolean) : [];
const hasImages = galleryImages.length > 0;

---

<div class="service-gallery flex flex-col gap-4" data-service-gallery>
  <p class="text-text-dark font-semibold text-sm uppercase tracking-wider">
    Real Results. Zero Filters.
  </p>

  {hasImages ? (
    <>
      <div class="embla service-gallery__main relative" role="region" aria-label={`${serviceName} image gallery`} tabindex="0">
        <div class="embla__viewport overflow-hidden bg-black aspect-4/3 min-h-80 lg:min-h-120 w-full" data-gallery-main-viewport>
          <div class="embla__container flex h-full">
            {galleryImages.map((img, i) => (
              <div class="embla__slide shrink-0 min-w-0 basis-full">
                <button
                  type="button"
                  class="gallery-main-trigger group relative block w-full h-full cursor-zoom-in"
                  data-gallery-main-trigger
                  data-gallery-index={i}
                  data-gallery-src={getCloudinaryImageUrl(img, 'f_auto,q_auto,w_1800')}
                  aria-label={`Open image ${i + 1} of ${galleryImages.length} in fullscreen`}
                >
                  <CldImage
                    src={img}
                    alt={`${serviceName} — real result ${i + 1}`}
                    width={1024}
                    height={800}
                    sizes="(max-width: 1024px) 100vw, 50vw"
                    class="w-full h-full object-cover"
                    loading={i === 0 ? 'eager' : 'lazy'}
                  />

                  <div class="absolute inset-0 bg-black/0 transition-colors duration-300 group-hover:bg-black/20" />

                  <div class="absolute right-3 bottom-3 bg-black/65 text-white text-xs font-medium px-3 py-1.5 rounded-full flex items-center gap-1.5">
                    <Icon name="tabler:zoom-in" size='sm' />
                    Full view
                  </div>
                </button>
              </div>
            ))}
          </div>
        </div>

        {galleryImages.length > 1 && (
          <>
            <button
              type="button"
              class="gallery-nav-btn absolute left-2 top-1/2 -translate-y-1/2 bg-black/60 hover:bg-black/80 text-white w-9 h-9 rounded-full flex items-center justify-center transition-all"
              data-gallery-prev
              aria-label="Previous image"
            >
              <Icon name="tabler:chevron-left" />
            </button>

            <button
              type="button"
              class="gallery-nav-btn absolute right-2 top-1/2 -translate-y-1/2 bg-black/60 hover:bg-black/80 text-white w-9 h-9 rounded-full flex items-center justify-center transition-all"
              data-gallery-next
              aria-label="Next image"
            >
              <Icon name="tabler:chevron-right" />
            </button>

            <div class="absolute top-3 right-3 bg-black/70 text-white text-xs font-semibold px-3 py-1 rounded-full">
              <span data-gallery-current>1</span>
              <span aria-hidden="true"> / </span>
              <span>{galleryImages.length}</span>
            </div>
          </>
        )}
      </div>

      {galleryImages.length > 1 && (
        <div class="embla-thumbs" data-gallery-thumbs>
          <div class="embla-thumbs__viewport overflow-hidden" data-gallery-thumbs-viewport>
            <div class="embla-thumbs__container flex gap-2">
              {galleryImages.map((img, i) => (
                <div class="embla-thumbs__slide shrink-0 py-2">
                  <button
                    type="button"
                    class="gallery-thumb w-20 h-16 overflow-hidden border-2 cursor-pointer"
                    data-gallery-thumb
                    data-gallery-index={i}
                    data-selected={i === 0 ? 'true' : 'false'}
                    aria-label={`Show image ${i + 1}`}
                    aria-current={i === 0 ? 'true' : 'false'}
                  >

                    <CldImage
                      src={img}
                      alt={`${serviceName} thumbnail ${i + 1}`}
                      width={80}
                      height={64}
                      sizes="100px"
                      class="w-full h-full object-cover"
                      loading={i === 0 ? 'eager' : 'lazy'}
                    />
                  </button>
                </div>
              ))}
            </div>
          </div>
        </div>
      )}
    </>
  ) : (
    <p class="text-sm text-text-muted">No gallery images available yet for this service.</p>
  )}
</div>

<style>
  .service-gallery [data-gallery-main-viewport] {
    touch-action: pan-y;
  }

  .gallery-main-trigger:focus-visible,
  .gallery-thumb:focus-visible,
  .gallery-nav-btn:focus-visible {
    outline: 2px solid #d4a843;
    outline-offset: 2px;
  }

  .gallery-thumb {
    border-color: transparent;
    transition: border-color 180ms ease, box-shadow 180ms ease, transform 180ms ease;
  }

  .gallery-thumb:hover {
    border-color: rgba(212, 168, 67, 0.55);
  }

  .gallery-thumb[data-selected='true'] {
    border-color: #d4a843;
    box-shadow: 0 0 0 1px rgba(212, 168, 67, 0.35);
    transform: translateY(-1px);
  }
</style>

<script>
  import EmblaCarousel from 'embla-carousel';
  import GLightbox from 'glightbox';

  function initServiceGallery(root: HTMLElement) {
    if (root.dataset.initialized === 'true') return;
    root.dataset.initialized = 'true';

    const mainViewport = root.querySelector<HTMLElement>('[data-gallery-main-viewport]');
    if (!mainViewport) return;

    const prevBtn = root.querySelector<HTMLButtonElement>('[data-gallery-prev]');
    const nextBtn = root.querySelector<HTMLButtonElement>('[data-gallery-next]');
    const currentCounter = root.querySelector<HTMLElement>('[data-gallery-current]');
    const thumbsViewport = root.querySelector<HTMLElement>('[data-gallery-thumbs-viewport]');

    const mainTriggers = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-gallery-main-trigger]'));
    const thumbButtons = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-gallery-thumb]'));

    const mainEmbla = EmblaCarousel(mainViewport, {
      loop: mainTriggers.length > 1,
      align: 'start',
      skipSnaps: false,
      dragFree: false,
    });

    const thumbsEmbla = thumbsViewport
      ? EmblaCarousel(thumbsViewport, {
          align: 'start',
          containScroll: 'keepSnaps',
          dragFree: true,
          loop: false,
        })
      : null;

    const lightboxElements = mainTriggers.map((trigger) => ({
      href: trigger.dataset.gallerySrc ?? '',
      type: 'image' as const,
      alt: trigger.getAttribute('aria-label') ?? '',
    }));

    let lightbox: ReturnType<typeof GLightbox> | null = null;

    const openLightboxAt = (index: number) => {
      if (!lightboxElements.length) return;

      lightbox?.destroy();
      lightbox = GLightbox({
        elements: lightboxElements as Parameters<typeof GLightbox>[0]['elements'],
        touchNavigation: true,
        loop: true,
        zoomable: true,
        draggable: true,
        openEffect: 'fade',
        closeEffect: 'fade',
        startAt: index,
      });

      lightbox.open();
    };

    const updateUI = () => {
      const selected = mainEmbla.selectedScrollSnap();

      if (currentCounter) currentCounter.textContent = String(selected + 1);

      thumbButtons.forEach((button, index) => {
        const isSelected = index === selected;
        button.dataset.selected = isSelected ? 'true' : 'false';
        button.setAttribute('aria-current', isSelected ? 'true' : 'false');
      });

      thumbsEmbla?.scrollTo(selected);
    };

    updateUI();

    mainEmbla.on('select', updateUI);
    mainEmbla.on('reInit', updateUI);

    prevBtn?.addEventListener('click', () => mainEmbla.scrollPrev());
    nextBtn?.addEventListener('click', () => mainEmbla.scrollNext());

    thumbButtons.forEach((button, index) => {
      button.addEventListener('click', () => mainEmbla.scrollTo(index));
    });

    mainTriggers.forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const index = Number.parseInt(trigger.dataset.galleryIndex ?? '0', 10);
        openLightboxAt(index);
      });
    });

    const onKeydown = (event: KeyboardEvent) => {
      if (event.key === 'ArrowLeft') {
        event.preventDefault();
        mainEmbla.scrollPrev();
      }

      if (event.key === 'ArrowRight') {
        event.preventDefault();
        mainEmbla.scrollNext();
      }
    };

    root.addEventListener('keydown', onKeydown);

    document.addEventListener(
      'astro:before-preparation',
      () => {
        root.removeEventListener('keydown', onKeydown);
        lightbox?.destroy();
        thumbsEmbla?.destroy();
        mainEmbla.destroy();
      },
      { once: true }
    );
  }

  function initServiceGalleries() {
    document.querySelectorAll<HTMLElement>('[data-service-gallery]').forEach(initServiceGallery);
  }

  document.addEventListener('astro:page-load', initServiceGalleries);
</script>
