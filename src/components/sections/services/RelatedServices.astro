---
import ServiceCard from '../../ui/ServiceCard.astro';
import type { Service } from '../../../data/services';

interface Props {
  services: Service[];
}

const { services } = Astro.props;
---

<section class="bg-off-white py-8 lg:py-14">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <h2
      class="text-text-dark font-bold text-center text-h2 mb-10"
    >
      You might also be interested in these services
    </h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((service, index) => (
        <div data-reveal="up" style={`--reveal-delay: ${index * 100}ms`}>
          <ServiceCard
            image={service.images[0]}
            title={service.name}
            description={service.description}
            href={`/services/${service.slug}`}
          />
        </div>
      ))}
    </div>

  </div>
</section>
