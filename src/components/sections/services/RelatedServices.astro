---
import ServiceCard from '../../ui/ServiceCard.astro';
import type { Service } from '../../../data/services';

interface Props {
  services: Service[];
}

const { services } = Astro.props;
---

<section class="bg-off-white py-10 lg:py-16 relative overflow-hidden border-b border-divider-light/70">
  <div class="motion-drift absolute -left-16 top-20 h-60 w-60 rounded-full bg-gold/10 blur-3xl"></div>
  <div class="motion-drift absolute -right-14 bottom-16 h-72 w-72 rounded-full bg-gold/8 blur-3xl" style="--float-delay: 1.1s"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col gap-10">
    <div data-reveal="blur" class="flex flex-col gap-3">
      <span class="inline-flex items-center gap-3 text-xs font-semibold uppercase tracking-wide text-gold-deep">
        <span class="h-px w-10 bg-gold"></span>
        Related services
      </span>
      <h2 class="text-text-dark font-bold text-h2">
        You might also be interested in these services.
      </h2>
      <p class="text-text-dark/72 leading-relaxed">
        If you are comparing options, these related services are the next best places to continue depending on the finish, protection, or restoration level you want.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((service, index) => (
        <div data-reveal="scale" style={`--reveal-delay: ${index * 120}ms; --float-delay: ${index * 0.5}s`} class="motion-float-slow motion-card-hover">
          <ServiceCard
            image={service.images[0]}
            title={service.name}
            description={service.description}
            href={`/services/${service.slug}`}
          />
        </div>
      ))}
    </div>
  </div>
</section>
